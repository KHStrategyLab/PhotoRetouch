<Window x:Class="PhotoRetouch.ColorInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview Background Color"
        Width="420"
        Height="150"
        MinWidth="360"
        MinHeight="140"
        Background="#171819"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextMain" Color="#F1F3F4"/>
        <SolidColorBrush x:Key="TextSub" Color="#B9C0C5"/>
        <SolidColorBrush x:Key="ControlBg" Color="#33373B"/>
        <SolidColorBrush x:Key="ControlStroke" Color="#555D64"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="HEX (#202224) or RGB (32,34,36)"
                   Foreground="{StaticResource TextSub}"
                   Margin="0,0,0,8"/>
        <TextBox x:Name="ColorTextBox"
                 Grid.Row="0"
                 Margin="0,26,0,0"
                 Height="32"
                 VerticalContentAlignment="Center"
                 Background="#202224"
                 Foreground="{StaticResource TextMain}"
                 BorderBrush="{StaticResource ControlStroke}"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Cancel" Width="82" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="OK" Width="82" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
