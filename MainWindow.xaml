<Window x:Class="PhotoRetouch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhotoRetouch"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PhotoRetouch Studio" Height="820" Width="1280"
        MinHeight="720" MinWidth="1100"
        Background="#171819"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#171819"/>
        <SolidColorBrush x:Key="TopBg" Color="#202224"/>
        <SolidColorBrush x:Key="PanelBg" Color="#242628"/>
        <SolidColorBrush x:Key="PanelSoft" Color="#2D3033"/>
        <SolidColorBrush x:Key="Stroke" Color="#3F4448"/>
        <SolidColorBrush x:Key="TextMain" Color="#F1F3F4"/>
        <SolidColorBrush x:Key="TextSub" Color="#B9C0C5"/>
        <SolidColorBrush x:Key="Accent" Color="#7D8A94"/>
        <SolidColorBrush x:Key="ControlBg" Color="#33373B"/>
        <SolidColorBrush x:Key="ControlBgHover" Color="#3B4045"/>
        <SolidColorBrush x:Key="ControlStroke" Color="#555D64"/>
        <SolidColorBrush x:Key="ControlStrokeSoft" Color="#474E54"/>
        <SolidColorBrush x:Key="ControlActive" Color="#7A8791"/>
        <SolidColorBrush x:Key="ControlActiveSoft" Color="#384148"/>
        <SolidColorBrush x:Key="ScrollTrack" Color="#212426"/>
        <SolidColorBrush x:Key="ScrollThumb" Color="#4A5157"/>
        <SolidColorBrush x:Key="ScrollThumbHover" Color="#596169"/>
        <SolidColorBrush x:Key="SwitchTrack" Color="#303438"/>
        <SolidColorBrush x:Key="SwitchTrackChecked" Color="#39434A"/>
        <SolidColorBrush x:Key="SwitchStroke" Color="#555D64"/>
        <SolidColorBrush x:Key="SwitchDot" Color="#A8B3BB"/>
        <SolidColorBrush x:Key="SliderTrack" Color="#2A2D30"/>
        <SolidColorBrush x:Key="SliderFill" Color="#3F4C55"/>
        <SolidColorBrush x:Key="SliderFillHover" Color="#4A5963"/>
        <SolidColorBrush x:Key="SliderThumb" Color="#718391"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="16" Height="16" Margin="0,0,7,0">
                                    <Ellipse x:Name="Outer" Fill="{StaticResource SwitchTrack}" Stroke="{StaticResource SwitchStroke}" StrokeThickness="1"/>
                                    <Ellipse x:Name="Inner" Width="7" Height="7" Fill="{StaticResource SwitchDot}" Opacity="0"/>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="{StaticResource ScrollThumbHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Fill" Value="{StaticResource SwitchTrackChecked}"/>
                                <Setter TargetName="Outer" Property="Stroke" Value="{StaticResource ControlActive}"/>
                                <Setter TargetName="Inner" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,16"/>
            <Setter Property="Foreground" Value="{StaticResource SliderFill}"/>
            <Setter Property="Background" Value="{StaticResource SliderTrack}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="32">
                            <Grid VerticalAlignment="Center" Height="24">
                                <Border Background="{TemplateBinding Background}" CornerRadius="3" Height="5" VerticalAlignment="Center"/>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Focusable="False" Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Focusable="False" Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="18" Height="18" Background="{StaticResource SliderThumb}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse x:Name="ThumbShape" Fill="{TemplateBinding Background}" Stroke="#8EA0AD" StrokeThickness="1.4"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbShape" Property="Fill" Value="#8193A0"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbShape" Property="Fill" Value="#91A6B5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="{StaticResource ScrollTrack}"/>
            <Setter Property="Foreground" Value="{StaticResource ScrollThumb}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}" Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track" Focusable="False" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Focusable="False" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Focusable="False" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="{TemplateBinding Foreground}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="{TemplateBinding Background}" CornerRadius="5" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbHover}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ControlActive}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Height" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PhotoListItemBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="8,8,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource TextMain}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TopBg}"
                BorderBrush="{StaticResource Stroke}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PhotoRetouch Studio" FontSize="20" FontWeight="SemiBold" Margin="0,0,14,0"/>
                    <Border Background="#353A3F" BorderBrush="#596169" BorderThickness="1" Padding="8,3">
                        <TextBlock Text="UI REVIEW" Foreground="#D4DADE" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="&#xC0AC;&#xC9C4; &#xBD88;&#xB7EC;&#xC624;&#xAE30;" Click="LoadPhotosButton_Click"/>
                    <Button Content="&#xC800;&#xC7A5;" Click="SavePhotoButton_Click"/>
                    <Button x:Name="CompareButton" Content="&#xC6D0;&#xBCF8; &#xBE44;&#xAD50;" PreviewMouseDown="CompareButton_PreviewMouseDown" PreviewMouseUp="CompareButton_PreviewMouseUp" MouseLeave="CompareButton_MouseLeave"/>
                    <Button Content="&#xCD08;&#xAE30;&#xD654;"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="1920 x 1280" Foreground="{StaticResource TextSub}" Margin="0,0,16,0"/>
                    <TextBlock Text="100%" Foreground="{StaticResource TextSub}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="PhotoListPanel"
                    Grid.Column="0"
                    Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource Stroke}"
                    BorderThickness="0,0,1,0"
                    Padding="16"
                    AllowDrop="True"
                    DragOver="PhotoDropTarget_DragOver"
                    Drop="PhotoDropTarget_Drop">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <Button Content="작업 폴더 새로고침"
                                Height="36"
                                Margin="0,0,0,10"
                                HorizontalContentAlignment="Center"
                                Click="RefreshWorkingFolderButton_Click"/>
                        <TextBlock Text="{Binding PhotoCountText}" Style="{StaticResource MutedText}" Margin="2,0,0,12"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <TextBlock Text="{Binding PhotoSelectionText}"
                                   Style="{StaticResource MutedText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <Button Content="&#xC124;&#xC815;"
                                Height="36"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                Click="SettingsButton_Click"/>
                    </StackPanel>

                    <Border Background="#1C1E20" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                        <Grid>
                            <Grid Visibility="{Binding EmptyPhotoListVisibility}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="180">
                                    <Border Height="96"
                                            BorderBrush="{StaticResource ControlStroke}"
                                            BorderThickness="1"
                                            Background="#24272A"
                                            Margin="0,0,0,12"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="LoadPhotosButton_Click">
                                        <TextBlock Text="+" FontSize="32" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="&#xC0AC;&#xC9C4; &#xBAA9;&#xB85D;" TextAlignment="Center"/>
                                    <TextBlock Text="JPG, PNG, TIFF" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding PhotoListVisibility}">
                                <ItemsControl ItemsSource="{Binding Photos}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource PhotoListItemBorder}"
                                                    MouseLeftButtonUp="PhotoItem_MouseLeftButtonUp">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="54"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="46" Height="46" Background="#101112" BorderBrush="{StaticResource ControlStrokeSoft}" BorderThickness="1">
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding DisplayInfo}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Background="{StaticResource AppBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="58"/>
                </Grid.RowDefinitions>

                <Border Margin="2"
                        Background="#101112"
                        BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="PreviewSurface"
                              Grid.Row="0"
                              Grid.RowSpan="2"
                              AllowDrop="True"
                              DragOver="PhotoDropTarget_DragOver"
                              Drop="PhotoDropTarget_Drop"
                              PreviewMouseLeftButtonDown="PreviewFrame_PreviewMouseLeftButtonDown"
                              PreviewMouseLeftButtonUp="PreviewFrame_PreviewMouseLeftButtonUp"
                              PreviewMouseMove="PreviewFrame_PreviewMouseMove"
                              PreviewMouseWheel="PreviewFrame_PreviewMouseWheel">
                            <Border Background="#25282B"
                                    BorderThickness="0"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <Grid ClipToBounds="True">
                                    <Grid x:Name="EditedMockPreview">
                                        <ItemsControl ItemsSource="{Binding SelectedPhotos}"
                                                      Visibility="{Binding PhotoPreviewVisibility}"
                                                      RenderTransformOrigin="{Binding PreviewZoomOrigin}">
                                            <ItemsControl.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="{Binding SplitZoomScale}" ScaleY="{Binding SplitZoomScale}"/>
                                                    <TranslateTransform X="{Binding SplitPanX}" Y="{Binding SplitPanY}"/>
                                                </TransformGroup>
                                            </ItemsControl.RenderTransform>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="{Binding DataContext.PreviewRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                 Columns="{Binding DataContext.PreviewColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#101112"
                                                            BorderThickness="0"
                                                            ClipToBounds="True"
                                                            Margin="0">
                                                        <Image Source="{Binding Image}"
                                                               Stretch="Uniform"
                                                               RenderTransformOrigin="{Binding PreviewZoomOrigin}">
                                                            <Image.RenderTransform>
                                                                <TransformGroup>
                                                                    <ScaleTransform ScaleX="{Binding PreviewZoomScale}"
                                                                                    ScaleY="{Binding PreviewZoomScale}"/>
                                                                    <TranslateTransform X="{Binding PreviewPanX}"
                                                                                        Y="{Binding PreviewPanY}"/>
                                                                </TransformGroup>
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Rectangle Fill="#2D3033" Margin="28" Visibility="{Binding MockPreviewVisibility}"/>
                                    </Grid>
                                    <Grid x:Name="OriginalMockPreview" Visibility="Collapsed">
                                        <ItemsControl ItemsSource="{Binding SelectedPhotos}"
                                                      Visibility="{Binding PhotoPreviewVisibility}"
                                                      RenderTransformOrigin="{Binding PreviewZoomOrigin}">
                                            <ItemsControl.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform ScaleX="{Binding SplitZoomScale}" ScaleY="{Binding SplitZoomScale}"/>
                                                    <TranslateTransform X="{Binding SplitPanX}" Y="{Binding SplitPanY}"/>
                                                </TransformGroup>
                                            </ItemsControl.RenderTransform>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="{Binding DataContext.PreviewRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                 Columns="{Binding DataContext.PreviewColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#101112"
                                                            BorderThickness="0"
                                                            ClipToBounds="True"
                                                            Margin="0">
                                                        <Image Source="{Binding BaseImage}"
                                                               Stretch="Uniform"
                                                               RenderTransformOrigin="{Binding PreviewZoomOrigin}">
                                                            <Image.RenderTransform>
                                                                <TransformGroup>
                                                                    <ScaleTransform ScaleX="{Binding PreviewZoomScale}"
                                                                                    ScaleY="{Binding PreviewZoomScale}"/>
                                                                    <TranslateTransform X="{Binding PreviewPanX}"
                                                                                        Y="{Binding PreviewPanY}"/>
                                                                </TransformGroup>
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Rectangle Fill="#272A2D" Margin="28" Visibility="{Binding MockPreviewVisibility}"/>
                                    </Grid>
                                    <TextBlock Text="Space &#xB204;&#xB974;&#xB294; &#xB3D9;&#xC548; &#xC6D0;&#xBCF8; &#xBCF4;&#xAE30;"
                                               Visibility="{Binding MockPreviewVisibility}"
                                               Foreground="#D4DADE"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="0"
                                Background="#33000000"
                                BorderBrush="#55000000"
                                BorderThickness="0,0,0,1"
                                IsHitTestVisible="False">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#33000000"
                                            Padding="10,3">
                                        <TextBlock Text="{Binding PreviewTitleText}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#1D2022" BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0" Padding="18,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="&#xC774;&#xC804;" Width="74" Click="PreviousPhotoButton_Click"/>
                            <Button Content="&#xB2E4;&#xC74C;" Width="74" Click="NextPhotoButton_Click"/>
                            <TextBlock Text="Frame 0 / 0" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Zoom" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider Width="160" Minimum="25" Maximum="200" Value="{Binding ZoomPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource Stroke}"
                    BorderThickness="1,0,0,0"
                    Padding="16,16,2,16">
                <ScrollViewer x:Name="RetouchPanelScrollViewer"
                              VerticalScrollBarVisibility="Visible"
                              Background="Transparent">
                    <StackPanel x:Name="RetouchPanelContent">
                        <TextBlock Text="&#xBCF4;&#xC815; &#xD328;&#xB110;" Style="{StaticResource SectionTitle}"/>

                        <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="&#xC801;&#xC6A9; &#xB300;&#xC0C1;" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <UniformGrid Columns="3">
                                    <RadioButton Content="&#xC804;&#xCCB4; &#xC5BC;&#xAD74;" Foreground="{StaticResource TextMain}" IsChecked="True" GroupName="TargetMode"/>
                                    <RadioButton Content="&#xC120;&#xD0DD; &#xC778;&#xBB3C;" Foreground="{StaticResource TextMain}" GroupName="TargetMode"/>
                                    <RadioButton Content="&#xBAA8;&#xB4E0; &#xC778;&#xBB3C;" Foreground="{StaticResource TextMain}" GroupName="TargetMode"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="&#xC778;&#xBB3C; &#xC120;&#xD0DD;" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <ComboBox ItemsSource="{Binding People}" DisplayMemberPath="Name" SelectedIndex="0" Height="32" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding People}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="5"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource ControlStroke}" BorderThickness="1" Padding="8,6" Margin="0,0,6,6">
                                                <TextBlock Text="{Binding ShortName}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding RetouchSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border AllowDrop="True"
                                            PreviewDragOver="RetouchSection_PreviewDragOver"
                                            PreviewDrop="RetouchSection_PreviewDrop"
                                            Padding="{Binding SectionPadding}"
                                            Margin="0,0,0,10"
                                            Background="Transparent">
                                        <Expander IsExpanded="{Binding IsExpanded}"
                                                  Expanded="RetouchSection_Expanded"
                                                  Foreground="{StaticResource TextMain}"
                                                  Background="{StaticResource PanelSoft}"
                                                  BorderBrush="{StaticResource Stroke}">
                                            <Expander.Header>
                                            <Grid Width="276">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Width="30"
                                                        Height="28"
                                                        Padding="0"
                                                        Margin="0,0,4,0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Content="&#x21BA;"
                                                        FontSize="16"
                                                        ToolTip="&#xC774; &#xBAA9;&#xB85D; &#xCD08;&#xAE30;&#xD654;"
                                                        Click="ResetRetouchSectionButton_Click"/>
                                                <Border Grid.Column="2"
                                                        Width="32"
                                                        Height="28"
                                                        Background="Transparent"
                                                        Cursor="SizeAll"
                                                        Visibility="{Binding DataContext.IsSectionOrderEditMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        ToolTip="&#xBAA9;&#xB85D; &#xC21C;&#xC11C; &#xBCC0;&#xACBD;"
                                                        PreviewMouseLeftButtonDown="SectionDragHandle_PreviewMouseLeftButtonDown"
                                                        PreviewMouseLeftButtonUp="SectionDragHandle_PreviewMouseLeftButtonUp"
                                                        PreviewMouseMove="SectionDragHandle_PreviewMouseMove">
                                                    <TextBlock Text="&#x2630;"
                                                               Foreground="{StaticResource TextSub}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            </Expander.Header>
                                            <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1,0,1,1" Padding="12">
                                            <ItemsControl ItemsSource="{Binding Controls}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <Grid x:Name="SliderEditor">
                                                                <TextBlock Text="{Binding Label}"/>
                                                                <TextBlock Text="{Binding Value, ElementName=ValueSlider, StringFormat={}{0:0}}" HorizontalAlignment="Right" Foreground="{StaticResource TextSub}"/>
                                                            </Grid>
                                                            <Slider x:Name="ValueSlider"
                                                                    Minimum="{Binding Minimum}"
                                                                    Maximum="{Binding Maximum}"
                                                                    Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                                    IsSnapToTickEnabled="False"
                                                                    PreviewMouseWheel="ValueSlider_PreviewMouseWheel"
                                                                    ValueChanged="ValueSlider_ValueChanged"
                                                                    PreviewMouseLeftButtonUp="ValueSlider_CommitValue"
                                                                    LostMouseCapture="ValueSlider_CommitValue"/>
                                                            <Grid x:Name="ColorEditor" Visibility="Collapsed" Margin="0,0,0,14">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Border Width="22" Height="22" Background="{Binding ColorValue}" BorderBrush="{StaticResource ControlStroke}" BorderThickness="1" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="{Binding ColorValue}" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid x:Name="ActionEditor" Visibility="Collapsed" Margin="0,0,0,14">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1" Content="{Binding ActionText}" Height="30" Padding="12,0" Margin="10,0,0,0"/>
                                                            </Grid>
                                                            <StackPanel x:Name="CurveEditor" Visibility="Collapsed" Margin="0,0,0,16">
                                                                <TextBlock Text="{Binding Label}" Margin="0,0,0,8"/>
                                                                <Border Height="190"
                                                                        Background="#101112"
                                                                        BorderBrush="{StaticResource ControlStroke}"
                                                                        BorderThickness="1">
                                                                    <Viewbox Stretch="Uniform">
                                                                        <Canvas Width="278"
                                                                                Height="188"
                                                                                Background="#151719"
                                                                                Cursor="Cross"
                                                                                MouseLeftButtonDown="CurveCanvas_MouseLeftButtonDown"
                                                                                MouseMove="CurveCanvas_MouseMove"
                                                                                MouseLeftButtonUp="CurveCanvas_MouseLeftButtonUp">
                                                                            <Polygon Points="{Binding CurveHistogramPoints}"
                                                                                     Fill="#30363B"
                                                                                     Opacity="0.58"
                                                                                     IsHitTestVisible="False"/>
                                                                            <Line X1="4" Y1="40" X2="274" Y2="40" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="4" Y1="76" X2="274" Y2="76" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="4" Y1="112" X2="274" Y2="112" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="4" Y1="148" X2="274" Y2="148" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="58" Y1="4" X2="58" Y2="184" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="112" Y1="4" X2="112" Y2="184" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="166" Y1="4" X2="166" Y2="184" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="220" Y1="4" X2="220" Y2="184" Stroke="#2B3034" StrokeThickness="1"/>
                                                                            <Line X1="4" Y1="184" X2="274" Y2="4" Stroke="#56616A" StrokeThickness="1.1" StrokeDashArray="4 4"/>
                                                                            <Polyline Points="{Binding CurvePolylinePoints}" Stroke="#D4DADE" StrokeThickness="2"/>
                                                                            <ItemsControl ItemsSource="{Binding CurvePoints}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <Canvas/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemContainerStyle>
                                                                                    <Style TargetType="ContentPresenter">
                                                                                        <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                                                        <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                                                                    </Style>
                                                                                </ItemsControl.ItemContainerStyle>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Ellipse Width="8"
                                                                                                 Height="8"
                                                                                                 Fill="#D4DADE"
                                                                                                 Stroke="#101112"
                                                                                                 StrokeThickness="1"
                                                                                                 Cursor="Hand"
                                                                                                 MouseLeftButtonDown="CurvePoint_MouseLeftButtonDown"
                                                                                                 MouseMove="CurvePoint_MouseMove"
                                                                                                 MouseLeftButtonUp="CurvePoint_MouseLeftButtonUp">
                                                                                            <Ellipse.Style>
                                                                                                <Style TargetType="Ellipse">
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                            <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                                                            <Setter Property="StrokeThickness" Value="2"/>
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding IsPendingDelete}" Value="True">
                                                                                                            <Setter Property="Opacity" Value="0.35"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Ellipse.Style>
                                                                                        </Ellipse>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Canvas>
                                                                    </Viewbox>
                                                                </Border>
                                                                <Grid Margin="0,10,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="120"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="&#xCC44;&#xB110;" VerticalAlignment="Center"/>
                                                                    <ComboBox Grid.Column="1"
                                                                              SelectedValue="{Binding CurveChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              SelectedValuePath="Tag"
                                                                              SelectionChanged="CurveChannelComboBox_SelectionChanged">
                                                                        <ComboBoxItem Content="&#xC804;&#xCCB4;" Tag="{x:Static local:CurveChannel.All}"/>
                                                                        <ComboBoxItem Content="R" Tag="{x:Static local:CurveChannel.Red}"/>
                                                                        <ComboBoxItem Content="G" Tag="{x:Static local:CurveChannel.Green}"/>
                                                                        <ComboBoxItem Content="B" Tag="{x:Static local:CurveChannel.Blue}"/>
                                                                    </ComboBox>
                                                                </Grid>
                                                                <Grid Margin="0,8,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="48"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="48"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="&#xC785;&#xB825;" Foreground="{StaticResource TextSub}" FontSize="11" VerticalAlignment="Center"/>
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding SelectedCurveInputText, Mode=OneWay}"
                                                                             IsEnabled="{Binding IsSelectedCurveInputEditable}"
                                                                             Tag="Input"
                                                                             Margin="6,0,0,0"
                                                                             KeyDown="CurvePointValueTextBox_KeyDown"
                                                                             LostFocus="CurvePointValueTextBox_LostFocus"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="&#xCD9C;&#xB825;"
                                                                               Foreground="{StaticResource TextSub}"
                                                                               FontSize="11"
                                                                               Margin="12,0,6,0"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBox Grid.Column="4"
                                                                             Text="{Binding SelectedCurveOutputText, Mode=OneWay}"
                                                                             IsEnabled="{Binding HasSelectedCurvePoint}"
                                                                             Tag="Output"
                                                                             KeyDown="CurvePointValueTextBox_KeyDown"
                                                                             LostFocus="CurvePointValueTextBox_LostFocus"/>
                                                                </Grid>
                                                                <Button Content="&#xD604;&#xC7AC; &#xCC44;&#xB110; &#xCD08;&#xAE30;&#xD654;"
                                                                        Height="28"
                                                                        Margin="0,10,0,0"
                                                                        Padding="10,0"
                                                                        HorizontalContentAlignment="Center"
                                                                        Click="ResetCurveChannelButton_Click"/>
                                                                <Grid Margin="0,10,0,0">
                                                                    <TextBlock Text="{Binding CurveStrengthLabel}"/>
                                                                    <TextBlock Text="{Binding Value, StringFormat={}{0:0}}" HorizontalAlignment="Right" Foreground="{StaticResource TextSub}"/>
                                                                </Grid>
                                                                <Slider Minimum="{Binding Minimum}"
                                                                        Maximum="{Binding Maximum}"
                                                                        Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                                        PreviewMouseWheel="ValueSlider_PreviewMouseWheel"
                                                                        ValueChanged="CurveAmountSlider_ValueChanged"
                                                                        PreviewMouseLeftButtonUp="CurveAmountSlider_CommitValue"
                                                                        LostMouseCapture="CurveAmountSlider_CommitValue"/>
                                                            </StackPanel>
                                                            <StackPanel x:Name="BackgroundLibraryEditor" Visibility="Collapsed" Margin="0,0,0,16">
                                                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,8"/>
                                                                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                                                              VerticalScrollBarVisibility="Disabled"
                                                                              CanContentScroll="True"
                                                                              PanningMode="HorizontalOnly">
                                                                    <ItemsControl ItemsSource="{Binding BackgroundOptions}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Width="86"
                                                                                        Background="{StaticResource ControlBg}"
                                                                                        BorderBrush="{StaticResource ControlStroke}"
                                                                                        BorderThickness="1"
                                                                                        Margin="0,0,8,0"
                                                                                        Padding="4">
                                                                                    <StackPanel>
                                                                                        <Border Height="48" Background="{Binding PreviewColor}" BorderBrush="{StaticResource ControlStrokeSoft}" BorderThickness="1"/>
                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                   Foreground="{StaticResource TextSub}"
                                                                                                   FontSize="11"
                                                                                                   TextTrimming="CharacterEllipsis"
                                                                                                   HorizontalAlignment="Center"
                                                                                                   Margin="0,5,0,0"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsColorPicker}" Value="True">
                                                                <Setter TargetName="SliderEditor" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ValueSlider" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ColorEditor" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActionButton}" Value="True">
                                                                <Setter TargetName="SliderEditor" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ValueSlider" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ActionEditor" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsBackgroundLibrary}" Value="True">
                                                                <Setter TargetName="SliderEditor" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ValueSlider" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="BackgroundLibraryEditor" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCurveEditor}" Value="True">
                                                                <Setter TargetName="SliderEditor" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ValueSlider" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="CurveEditor" Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            </Border>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.ColumnSpan="3"
                  Background="Transparent"
                  Visibility="{Binding PreviewProcessingVisibility}"
                  Panel.ZIndex="99">
                <Border Background="#2D3033"
                        Padding="14,8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="프리뷰 생성 중..."
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMain}"/>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
