<Window x:Class="PhotoRetouch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="620"
        Height="540"
        MinWidth="560"
        MinHeight="480"
        Background="#171819"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelSoft" Color="#2D3033"/>
        <SolidColorBrush x:Key="Stroke" Color="#3F4448"/>
        <SolidColorBrush x:Key="TextMain" Color="#F1F3F4"/>
        <SolidColorBrush x:Key="TextSub" Color="#B9C0C5"/>
        <SolidColorBrush x:Key="ControlBg" Color="#33373B"/>
        <SolidColorBrush x:Key="ControlStroke" Color="#555D64"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#202224"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <TabControl>
            <TabItem Header="색 관리">
                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="색 관리" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <RadioButton x:Name="AutomaticColorManagementRadioButton" Content="자동 색 관리" GroupName="ColorManagementMode" Checked="ColorManagementMode_Changed"/>
                        <TextBlock Text="이미지 ICC가 있으면 사용하고, 없으면 sRGB로 간주합니다. 표시 프로파일을 찾지 못하면 sRGB로 보여줍니다."
                                   Foreground="{StaticResource TextSub}" TextWrapping="Wrap" Margin="20,-4,0,12"/>

                        <RadioButton x:Name="ManualColorManagementRadioButton" Content="수동 표시 프로파일" GroupName="ColorManagementMode" Checked="ColorManagementMode_Changed"/>
                        <Grid Margin="20,-4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ManualProfilePathTextBox" IsReadOnly="True" Text="sRGB IEC61966-2.1"/>
                            <Button x:Name="LoadProfileButton" Grid.Column="1" Content="프로파일 불러오기" Margin="8,0,0,0" Click="LoadProfileButton_Click"/>
                        </Grid>

                        <RadioButton x:Name="DisabledColorManagementRadioButton" Content="색 관리 끄기" GroupName="ColorManagementMode" Checked="ColorManagementMode_Changed"/>
                        <TextBlock Text="프로그램의 별도 색 변환을 끄고 Windows/WPF 기본 표시 방식으로 보여줍니다."
                                   Foreground="{StaticResource TextSub}" TextWrapping="Wrap" Margin="20,-4,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="프리뷰">
                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="프리뷰 성능" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <RadioButton x:Name="PreviewOriginalSizeRadioButton"
                                     Content="원본대로"
                                     GroupName="PreviewSizeMode"
                                     Checked="PreviewSizeMode_Changed"/>
                        <RadioButton x:Name="PreviewCustomSizeRadioButton"
                                     Content="긴쪽 최대 크기 사용"
                                     GroupName="PreviewSizeMode"
                                     Checked="PreviewSizeMode_Changed"/>

                        <Grid Margin="20,-2,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="최대 긴쪽" VerticalAlignment="Center"/>
                            <TextBox x:Name="PreviewMaxLongSideTextBox"
                                     Grid.Column="1"
                                     PreviewTextInput="PreviewMaxLongSideTextBox_PreviewTextInput"/>
                            <TextBlock Grid.Column="2" Text="px" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <TextBlock Text="입력값은 800px 이상, 4000px 이하로 제한됩니다. 예: 1200px"
                                   Foreground="{StaticResource TextSub}"
                                   TextWrapping="Wrap"
                                   Margin="20,0,0,16"/>

                        <Button Content="설정 적용"
                                Width="110"
                                HorizontalAlignment="Left"
                                Click="ApplyPreviewSettingsButton_Click"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="성능">
                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="프리뷰 엔진" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <RadioButton x:Name="CpuPreviewEngineRadioButton"
                                     Content="안정 모드 - CPU 엔진"
                                     GroupName="PreviewEngineMode"
                                     Checked="PreviewEngineMode_Changed"/>
                        <TextBlock Text="호환성을 우선하는 기본 프리뷰 계산 방식입니다."
                                   Foreground="{StaticResource TextSub}"
                                   TextWrapping="Wrap"
                                   Margin="20,-4,0,12"/>

                        <RadioButton x:Name="GpuPreviewEngineRadioButton"
                                     Content="가속 모드 - GPU 엔진"
                                     GroupName="PreviewEngineMode"
                                     Checked="PreviewEngineMode_Changed"/>
                        <TextBlock Text="구현 중입니다. 지원되는 그래픽 장치에서 프리뷰 계산을 빠르게 처리하는 옵션으로 준비할 예정입니다."
                                   Foreground="{StaticResource TextSub}"
                                   TextWrapping="Wrap"
                                   Margin="20,-4,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="작업 폴더">
                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="작업 폴더" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="사진 불러오기 창이 처음 열릴 위치를 지정합니다."
                                   Foreground="{StaticResource TextSub}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WorkingFolderPathTextBox" IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Content="찾아보기"
                                    Margin="8,0,0,0"
                                    Click="BrowseWorkingFolderButton_Click"/>
                        </Grid>

                        <Button Content="설정 적용"
                                Width="110"
                                HorizontalAlignment="Left"
                                Click="ApplyWorkingFolderButton_Click"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="단축키">
                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="단축키" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="파일 이름 바꾸기" VerticalAlignment="Center"/>
                            <Button x:Name="RenameShortcutButton" Grid.Column="1" HorizontalContentAlignment="Center" Click="ShortcutButton_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="원본 비교 보기" VerticalAlignment="Center"/>
                            <Button x:Name="CompareShortcutButton" Grid.Column="1" HorizontalContentAlignment="Center" Click="ShortcutButton_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xBAA9;&#xB85D; &#xC21C;&#xC11C; &#xBCC0;&#xACBD; &#xBAA8;&#xB4DC;" VerticalAlignment="Center"/>
                            <Button x:Name="ToggleSectionOrderEditShortcutButton" Grid.Column="1" HorizontalContentAlignment="Center" Click="ShortcutButton_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xD55C; &#xB2E8;&#xACC4; &#xB418;&#xB3CC;&#xB9AC;&#xAE30;" VerticalAlignment="Center"/>
                            <Button x:Name="UndoShortcutButton" Grid.Column="1" HorizontalContentAlignment="Center" Click="ShortcutButton_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xB2E4;&#xC2DC; &#xC2E4;&#xD589;" VerticalAlignment="Center"/>
                            <Button x:Name="RedoShortcutButton" Grid.Column="1" HorizontalContentAlignment="Center" Click="ShortcutButton_Click"/>
                        </Grid>

                        <TextBlock Text="마우스 조작 보조키" FontWeight="SemiBold" Margin="0,4,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="사진 선택 추가" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AddSelectionModifierComboBox" Grid.Column="1" SelectionChanged="ModifierComboBox_SelectionChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="사진 범위 선택" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RangeSelectionModifierComboBox" Grid.Column="1" SelectionChanged="ModifierComboBox_SelectionChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="전체 분할 화면 조작" VerticalAlignment="Center"/>
                            <ComboBox x:Name="WholeSplitModifierComboBox" Grid.Column="1" SelectionChanged="ModifierComboBox_SelectionChanged"/>
                        </Grid>

                        <Button Content="기본값으로 되돌리기" Width="150" HorizontalAlignment="Left" Margin="0,8,0,0" Click="ResetShortcutsButton_Click"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
