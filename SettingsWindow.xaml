<Window x:Class="PhotoRetouch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="540"
        Height="440"
        MinWidth="500"
        MinHeight="400"
        Background="#171819"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelSoft" Color="#2D3033"/>
        <SolidColorBrush x:Key="Stroke" Color="#3F4448"/>
        <SolidColorBrush x:Key="TextMain" Color="#F1F3F4"/>
        <SolidColorBrush x:Key="TextSub" Color="#B9C0C5"/>
        <SolidColorBrush x:Key="ControlBg" Color="#33373B"/>
        <SolidColorBrush x:Key="ControlStroke" Color="#555D64"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="설정" FontSize="20" FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Background="{StaticResource PanelSoft}"
                BorderBrush="{StaticResource Stroke}"
                BorderThickness="1"
                Padding="14"
                Margin="0,18,0,16">
            <StackPanel>
                <TextBlock Text="색 관리" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <RadioButton x:Name="AutomaticColorManagementRadioButton"
                             Content="자동 색 관리"
                             GroupName="ColorManagementMode"
                             Checked="ColorManagementMode_Changed"/>
                <TextBlock Text="이미지 ICC가 있으면 사용하고, 없으면 sRGB로 간주합니다. 모니터 프로파일을 찾지 못하면 sRGB로 표시합니다."
                           Foreground="{StaticResource TextSub}"
                           TextWrapping="Wrap"
                           Margin="20,-4,0,12"/>

                <RadioButton x:Name="ManualColorManagementRadioButton"
                             Content="수동 표시 프로파일"
                             GroupName="ColorManagementMode"
                             Checked="ColorManagementMode_Changed"/>
                <Grid Margin="20,-4,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ManualProfilePathTextBox"
                             Height="32"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center"
                             Foreground="{StaticResource TextMain}"
                             Background="#202224"
                             BorderBrush="{StaticResource ControlStroke}"
                             Text="sRGB IEC61966-2.1"/>
                    <Button x:Name="LoadProfileButton"
                            Grid.Column="1"
                            Content="프로파일 불러오기"
                            Margin="8,0,0,0"
                            Click="LoadProfileButton_Click"/>
                </Grid>

                <RadioButton x:Name="DisabledColorManagementRadioButton"
                             Content="색 관리 끄기"
                             GroupName="ColorManagementMode"
                             Checked="ColorManagementMode_Changed"/>
                <TextBlock Text="프로그램의 별도 색 변환을 끄고 Windows/WPF 기본 표시 방식으로 보여줍니다."
                           Foreground="{StaticResource TextSub}"
                           TextWrapping="Wrap"
                           Margin="20,-4,0,0"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                Content="닫기"
                Width="88"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
